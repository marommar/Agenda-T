{
  "name": "agenda-t",
  "version": "1.0.2",
  "description": "Agenda-T Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder -w",
    "package": "electron-packager . Agenda-T --platform=win32 --arch=x64 --out=dist --overwrite"
  },
  "build": {
    "appId": "com.agenda-t.app",
    "productName": "Agenda-T",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "Luxe Salon",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "exceljs": "^4.4.0",
    "node-cron": "^4.2.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.0"
  }
}
